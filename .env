# إعدادات بوت تحميل الأنمي

# اللغة
BOT_LANGUAGE=ar

# إعدادات التحميل
DEFAULT_QUALITY=720p
DEFAULT_COMPRESSION=true
MAX_FILE_SIZE_MB=16

# إعدادات الضغط
COMPRESSION_QUALITY=medium
TARGET_SIZE_MB=15

# إعدادات المتصفح
HEADLESS_MODE=false
BROWSER_TIMEOUT=30

# إعدادات الواتساب
MESSAGE_DELAY=1
FILE_SEND_DELAY=2
